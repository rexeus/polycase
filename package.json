{
  "name": "@rexeus/polycase",
  "private": true,
  "description": "Case conversion utilities for TypeScript",
  "scripts": {
    "typecheck": "turbo typecheck",
    "build": "turbo build && pnpm size",
    "size": "size-limit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix && pnpm format",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo test",
    "publish:dry": "pnpm publish -r --dry-run --no-git-checks",
    "ci:publish": "pnpm publish -r --provenance",
    "prepare:commit": "pnpm run format && pnpm run lint:fix && pnpm run typecheck && pnpm run build && pnpm run test"
  },
  "keywords": [
    "casing",
    "utility",
    "typescript"
  ],
  "author": "Dennis Wentzien <dw@rexeus.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rexeus/polycase.git"
  },
  "bugs": {
    "url": "https://github.com/rexeus/polycase/issues"
  },
  "homepage": "https://github.com/rexeus/polycase#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@changesets/cli": "2.29.6",
    "@faker-js/faker": "^10.4.0",
    "@size-limit/file": "^12.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "size-limit": "^12.0.1",
    "tsdown": "0.21.8",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
