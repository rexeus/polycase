{
  "name": "polycase",
  "version": "0.0.1",
  "description": "Case conversion utilities for TypeScript",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "build": "tsdown",
    "prepack": " pnpm run build",
    "preversion": "pnpm run build",
    "test": "vitest --run"
  },
  "keywords": [
    "casing",
    "utility",
    "typescript"
  ],
  "author": "Dennis Wentzien <dw@rexeus.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rexeus/polycase.git",
    "directory": "packages/polycase"
  },
  "bugs": {
    "url": "https://github.com/rexeus/polycase/issues"
  },
  "homepage": "https://github.com/rexeus/polycase#readme",
  "engines": {
    "node": ">=20.0.0"
  }
}
